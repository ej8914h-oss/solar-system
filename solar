<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<title>ORRERY — 태양계 시뮬레이터 (멀티플레이)</title>
<style>
  /* =========================================================
     디자인 토큰 (Universe Sandbox / Space Engine 영감)
     딥스페이스 팔레트 + 글래스모피즘 + 모노스페이스 텔레메트리
     ========================================================= */
  :root {
    --bg-void:#04050a; --bg-nebula:#0a1024;
    --glass:rgba(14,22,44,0.55); --glass-strong:rgba(10,16,34,0.82);
    --stroke:rgba(120,180,255,0.18); --stroke-hot:rgba(120,200,255,0.55);
    --text:#dfe9ff; --text-dim:#8aa0c8;
    --accent:#5ad6e0; --accent-2:#9b7bff; --sun:#ffcf6e; --danger:#ff6b6b;
    --ok:#7cff9b;
    --mono:"SF Mono","JetBrains Mono","Cascadia Code","Consolas",ui-monospace,monospace;
    --sans:"Inter","SF Pro Display",system-ui,-apple-system,"Segoe UI",sans-serif;
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  html,body { width:100%; height:100%; overflow:hidden; background:var(--bg-void); color:var(--text); font-family:var(--sans); user-select:none; }
  #stage { position:fixed; inset:0; display:block; cursor:grab; }
  #stage:active { cursor:grabbing; }

  .glass {
    background:var(--glass);
    backdrop-filter:blur(18px) saturate(140%); -webkit-backdrop-filter:blur(18px) saturate(140%);
    border:1px solid var(--stroke); border-radius:16px;
    box-shadow:0 12px 40px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.06);
  }

  /* ---------- 상단 시간 제어 바 ---------- */
  #topbar { position:fixed; top:14px; left:50%; transform:translateX(-50%); display:flex; align-items:center; gap:6px; padding:8px 10px; z-index:20; }
  #topbar .brand { display:flex; flex-direction:column; line-height:1; margin:0 12px 0 6px; }
  #topbar .brand b { font-size:14px; letter-spacing:3px; font-weight:700; }
  #topbar .brand span { font-family:var(--mono); font-size:9px; color:var(--text-dim); letter-spacing:1px; margin-top:3px; }
  .tbtn { font-family:var(--mono); font-size:12px; color:var(--text); background:rgba(255,255,255,0.04); border:1px solid var(--stroke); padding:9px 12px; border-radius:10px; cursor:pointer; transition:all .15s ease; white-space:nowrap; }
  .tbtn:hover { border-color:var(--stroke-hot); background:rgba(90,214,224,0.10); }
  .tbtn.active { background:linear-gradient(180deg,rgba(90,214,224,0.28),rgba(90,214,224,0.10)); border-color:var(--accent); color:#eafdff; box-shadow:0 0 14px rgba(90,214,224,0.35); }
  .tbtn.pause.active { background:linear-gradient(180deg,rgba(255,107,107,.28),rgba(255,107,107,.08)); border-color:var(--danger); box-shadow:0 0 14px rgba(255,107,107,.3); }
  .sep { width:1px; height:26px; background:var(--stroke); margin:0 4px; }

  /* ---------- 멀티플레이 패널 (좌측 상단) ---------- */
  #mp { position:fixed; top:14px; left:14px; width:236px; max-width:calc(100vw - 28px); z-index:19; overflow:hidden; }
  .mp-head { display:flex; align-items:center; gap:8px; padding:12px 14px; cursor:pointer; }
  .mp-head b { font-size:13px; letter-spacing:1px; }
  .mp-head .mp-status { margin-left:auto; font-family:var(--mono); font-size:10px; color:var(--text-dim); }
  .mp-head .chev { font-size:10px; color:var(--text-dim); transition:transform .2s; }
  #mp.collapsed .chev { transform:rotate(-90deg); }
  #mp.collapsed .mp-body { display:none; }
  .dot { width:9px; height:9px; border-radius:50%; background:var(--danger); box-shadow:0 0 8px currentColor; color:var(--danger); }
  .dot.connecting { background:var(--sun); color:var(--sun); animation:blink 1s infinite; }
  .dot.on { background:var(--ok); color:var(--ok); }
  .mp-body { padding:0 14px 14px; }
  .mp-body label { display:block; font-size:10px; color:var(--text-dim); letter-spacing:1px; text-transform:uppercase; margin-bottom:10px; }
  .mp-body input { width:100%; margin-top:5px; font-family:var(--mono); font-size:12px; color:var(--text); background:rgba(0,0,0,0.25); border:1px solid var(--stroke); border-radius:9px; padding:8px 10px; outline:none; }
  .mp-body input:focus { border-color:var(--accent); }
  #mpConnect { width:100%; text-align:center; padding:10px; }
  #mpConnect.on { border-color:var(--danger); color:#ffd6d6; background:rgba(255,107,107,.12); }
  .mp-adv { margin-top:10px; }
  .mp-adv summary { font-size:10px; color:var(--text-dim); cursor:pointer; letter-spacing:1px; }
  .mp-roster { display:flex; flex-wrap:wrap; gap:6px; margin-top:12px; }
  .chip { display:flex; align-items:center; gap:6px; font-family:var(--mono); font-size:11px; padding:4px 9px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid var(--stroke); }
  .chip .cd { width:8px; height:8px; border-radius:50%; box-shadow:0 0 6px currentColor; }
  .mp-note { margin-top:10px; font-size:10px; line-height:1.5; color:var(--text-dim); }

  /* ---------- 우측 행성 정보 ---------- */
  #info { position:fixed; top:14px; right:14px; width:300px; max-width:calc(100vw - 28px); padding:18px; z-index:18; transform:translateX(120%); transition:transform .35s cubic-bezier(.2,.8,.2,1); }
  #info.show { transform:translateX(0); }
  #info .close { position:absolute; top:12px; right:12px; cursor:pointer; color:var(--text-dim); font-size:18px; line-height:1; }
  #info .close:hover { color:var(--text); }
  #info .swatch { width:44px; height:44px; border-radius:50%; margin-bottom:12px; box-shadow:0 0 22px currentColor; }
  #info h2 { font-size:22px; letter-spacing:1px; margin-bottom:2px; }
  #info .tag { font-family:var(--mono); font-size:10px; color:var(--accent); letter-spacing:2px; text-transform:uppercase; }
  #info .desc { margin:14px 0; font-size:13px; line-height:1.6; color:var(--text-dim); }
  .stat { display:flex; justify-content:space-between; align-items:baseline; padding:8px 0; border-bottom:1px dashed rgba(120,180,255,0.12); }
  .stat:last-child { border-bottom:none; }
  .stat .k { font-size:12px; color:var(--text-dim); }
  .stat .v { font-family:var(--mono); font-size:13px; color:var(--text); }

  /* ---------- 좌측 하단 텔레메트리 ---------- */
  #telemetry { position:fixed; left:14px; bottom:14px; width:248px; max-width:calc(100vw - 28px); padding:14px 16px; z-index:16; font-family:var(--mono); }
  #telemetry .title { font-size:10px; letter-spacing:2px; color:var(--accent); margin-bottom:10px; display:flex; align-items:center; gap:7px; }
  #telemetry .title::before { content:""; width:7px; height:7px; border-radius:50%; background:var(--accent); box-shadow:0 0 8px var(--accent); animation:blink 1.6s infinite; }
  @keyframes blink { 50% { opacity:.25; } }
  .tele-row { display:flex; justify-content:space-between; font-size:11px; padding:3px 0; }
  .tele-row .lk { color:var(--text-dim); }
  .tele-row .lv { color:var(--text); }

  /* ---------- 우측 하단 이벤트/옵션 ---------- */
  #dock { position:fixed; right:14px; bottom:14px; z-index:16; display:flex; flex-direction:column; gap:8px; align-items:flex-end; }
  .dock-group { display:flex; gap:6px; padding:8px; }
  .ebtn { font-family:var(--mono); font-size:11px; color:var(--text); background:rgba(255,255,255,0.04); border:1px solid var(--stroke); padding:9px 11px; border-radius:10px; cursor:pointer; transition:all .15s ease; display:flex; flex-direction:column; align-items:center; gap:4px; min-width:56px; }
  .ebtn:hover { border-color:var(--stroke-hot); background:rgba(155,123,255,0.12); }
  .ebtn .ic { font-size:16px; }
  .toggle.on { border-color:var(--accent); color:var(--accent); background:rgba(90,214,224,0.12); }

  #hint { position:fixed; left:50%; bottom:16px; transform:translateX(-50%); font-family:var(--mono); font-size:11px; color:var(--text-dim); padding:8px 16px; z-index:14; pointer-events:none; text-align:center; transition:opacity .6s ease; }

  #spawnBanner { position:fixed; top:78px; left:50%; transform:translateX(-50%); font-family:var(--mono); font-size:12px; letter-spacing:1px; padding:9px 18px; z-index:22; color:#eafdff; border:1px solid var(--accent); background:rgba(90,214,224,0.14); border-radius:999px; display:none; align-items:center; gap:8px; }
  #spawnBanner.show { display:flex; animation:pulseB 1.4s infinite; }
  @keyframes pulseB { 50% { box-shadow:0 0 18px rgba(90,214,224,.5); } }

  /* ---------- 반응형 ---------- */
  @media (max-width:820px) {
    #topbar { top:8px; gap:4px; padding:6px; flex-wrap:wrap; justify-content:center; max-width:calc(100vw - 16px); }
    #topbar .brand { display:none; }
    .tbtn { padding:8px 9px; font-size:11px; }
    #mp { top:auto; bottom:auto; }
    #telemetry { width:160px; padding:11px 12px; bottom:10px; left:10px; }
    .tele-row { font-size:10px; }
    #dock { right:10px; bottom:10px; }
    .ebtn { min-width:46px; font-size:10px; padding:8px; }
    #info { width:260px; }
    #hint { display:none; }
  }
  @media (max-width:820px) {
    #mp { left:10px; top:64px; width:200px; }
    #mp.collapsed { width:auto; }
  }
</style>
</head>
<body>

<canvas id="stage"></canvas>

<!-- 상단: 시간 제어 -->
<div id="topbar" class="glass">
  <div class="brand"><b>ORRERY</b><span>SOLAR SIM · MP</span></div>
  <button class="tbtn pause" data-speed="0">❚❚ 정지</button>
  <div class="sep"></div>
  <button class="tbtn active" data-speed="1">1×</button>
  <button class="tbtn" data-speed="10">10×</button>
  <button class="tbtn" data-speed="100">100×</button>
  <button class="tbtn" data-speed="1000">1000×</button>
</div>

<!-- 좌측 상단: 멀티플레이 -->
<div id="mp" class="glass">
  <div class="mp-head" id="mpHead">
    <span class="dot" id="mpDot"></span><b>멀티플레이</b>
    <span class="mp-status" id="mpStatus">오프라인</span>
    <span class="chev" id="mpChev">▾</span>
  </div>
  <div class="mp-body">
    <label>닉네임<input id="mpName" type="text" maxlength="14" /></label>
    <label>방 코드<input id="mpRoom" type="text" maxlength="20" /></label>
    <button id="mpConnect" class="tbtn">접속</button>
    <details class="mp-adv"><summary>고급 설정</summary>
      <label style="margin-top:8px;">MQTT 브로커<input id="mpBroker" type="text" /></label>
    </details>
    <div class="mp-roster" id="mpRoster"></div>
    <p class="mp-note">공개 테스트 브로커로 동작합니다. 같은 <b>방 코드</b>를 친구에게 알려주면 같은 우주에 접속합니다.</p>
  </div>
</div>

<!-- 생성 모드 배너 -->
<div id="spawnBanner"><span id="spawnText"></span> · 화면을 클릭/탭 하세요</div>

<!-- 우측: 행성 정보 -->
<aside id="info" class="glass">
  <div class="close" id="infoClose">✕</div>
  <div class="swatch" id="infoSwatch"></div>
  <div class="tag" id="infoTag">PLANET</div>
  <h2 id="infoName">—</h2>
  <p class="desc" id="infoDesc"></p>
  <div id="infoStats"></div>
</aside>

<!-- 좌측 하단: 텔레메트리 -->
<div id="telemetry" class="glass">
  <div class="title">SIMULATION TELEMETRY</div>
  <div class="tele-row"><span class="lk">TIME WARP</span><span class="lv" id="tWarp">1×</span></div>
  <div class="tele-row"><span class="lk">TARGET</span><span class="lv" id="tTarget">SUN</span></div>
  <div class="tele-row"><span class="lk">PLAYERS</span><span class="lv" id="tPlayers">1</span></div>
  <div class="tele-row"><span class="lk">BODIES</span><span class="lv" id="tBodies">0</span></div>
  <div class="tele-row"><span class="lk">ELAPSED</span><span class="lv" id="tElapsed">0d</span></div>
  <div class="tele-row"><span class="lk">FPS</span><span class="lv" id="tFps">60</span></div>
</div>

<!-- 우측 하단: 이벤트/옵션 -->
<div id="dock">
  <div class="dock-group glass">
    <button class="ebtn" id="spAst"><span class="ic">☄</span>소행성</button>
    <button class="ebtn" id="spCom"><span class="ic">✦</span>혜성</button>
    <button class="ebtn" id="spBh"><span class="ic">◉</span>블랙홀</button>
  </div>
  <div class="dock-group glass">
    <button class="ebtn toggle on" id="tgOrbit"><span class="ic">◯</span>궤도</button>
    <button class="ebtn toggle on" id="tgLabel"><span class="ic">A</span>이름</button>
    <button class="ebtn" id="resetView"><span class="ic">⊹</span>리셋</button>
  </div>
</div>

<div id="hint">휠: 확대/축소 · 드래그: 이동 · 클릭: 정보 · 더블클릭: 추적</div>

<!-- 멀티플레이용 MQTT 클라이언트 (실시간 동기화) -->
<script src="https://unpkg.com/mqtt@5/dist/mqtt.min.js"></script>
<script>
"use strict";
/* =========================================================================
   ORRERY — 태양계 우주 시뮬레이터 (실시간 멀티플레이)
   순수 HTML/CSS/JS · 렌더링 라이브러리 없음 · Canvas 2D
   동기화: 공개 MQTT 브로커(WebSocket) 통해 브라우저끼리 직접 통신
   구조: Star/Sun/Planet/Asteroid/Comet/BlackHole + Camera + Net + Simulation
   ========================================================================= */

const TAU = Math.PI * 2;
const rand = (a, b) => a + Math.random() * (b - a);
const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
const now = () => performance.now();

/* 플레이어 색상 팔레트 (id 해시로 결정) */
const PALETTE = ["#5ad6e0","#9b7bff","#ff9bd0","#7cff9b","#ffd06b","#ff8f6b","#6bb8ff","#d06bff"];
function colorFor(id){ let h=0; for(const c of id) h=(h*31+c.charCodeAt(0))>>>0; return PALETTE[h%PALETTE.length]; }

/* ============================ Star ============================ */
class Star {
  constructor(w, h){ this.x=rand(0,w); this.y=rand(0,h); this.size=rand(0.4,1.6); this.baseAlpha=rand(0.25,0.9); this.phase=rand(0,TAU); this.speed=rand(0.6,2.2); this.depth=rand(0.02,0.12); }
  draw(ctx, t, camX, camY){
    const tw=this.baseAlpha*(0.55+0.45*Math.sin(t*this.speed+this.phase));
    ctx.globalAlpha=tw; ctx.fillStyle="#cfe2ff";
    ctx.beginPath(); ctx.arc(this.x-camX*this.depth, this.y-camY*this.depth, this.size, 0, TAU); ctx.fill();
  }
}

/* ============================ Camera ============================ */
class Camera {
  constructor(){ this.x=0; this.y=0; this.zoom=1; this.target=null; }
  toScreen(wx, wy, cx, cy){ return { x:(wx-this.x)*this.zoom+cx, y:(wy-this.y)*this.zoom+cy }; }
  toWorld(sx, sy, cx, cy){ return { x:(sx-cx)/this.zoom+this.x, y:(sy-cy)/this.zoom+this.y }; }
  follow(){ if(this.target){ this.x+=(this.target.wx-this.x)*0.12; this.y+=(this.target.wy-this.y)*0.12; } }
}

/* ============================ Sun ============================ */
class Sun {
  constructor(){ this.wx=0; this.wy=0; this.radius=26; this.name="태양"; this.color="#ffcf6e"; this.type="STAR";
    this.info={ radius:"696,340 km", dist:"—", period:"—", rotation:"약 25일 (적도)", moons:"8개 행성",
      desc:"태양계 질량의 99.8%를 차지하는 G형 주계열성. 모든 행성이 그 중력에 묶여 공전합니다." }; }
  draw(ctx, cam, cx, cy, t){
    const s=cam.toScreen(this.wx,this.wy,cx,cy), r=this.radius*cam.zoom;
    const glow=ctx.createRadialGradient(s.x,s.y,r*0.2,s.x,s.y,r*6);
    glow.addColorStop(0,"rgba(255,210,120,0.55)"); glow.addColorStop(0.3,"rgba(255,150,60,0.18)"); glow.addColorStop(1,"rgba(255,120,40,0)");
    ctx.globalAlpha=1; ctx.fillStyle=glow; ctx.beginPath(); ctx.arc(s.x,s.y,r*6,0,TAU); ctx.fill();
    const pulse=1+0.04*Math.sin(t*2);
    const core=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,r*pulse);
    core.addColorStop(0,"#fff6df"); core.addColorStop(0.55,"#ffd06b"); core.addColorStop(1,"#ff9b3d");
    ctx.fillStyle=core; ctx.beginPath(); ctx.arc(s.x,s.y,r*pulse,0,TAU); ctx.fill();
  }
}

/* ============================ Planet ============================
   동기화를 위해 위치를 "절대 경과일(elapsedDays)"의 함수로 계산.
   모든 클라이언트가 동일한 elapsedDays를 공유하면 행성 위치가 일치한다. */
class Planet {
  constructor(cfg){
    this.name=cfg.name; this.color=cfg.color; this.radius=cfg.radius; this.orbit=cfg.orbit;
    this.periodDays=cfg.periodDays; this.angle0=cfg.angle0; this.angle=cfg.angle0;
    this.hasRing=cfg.hasRing||false; this.type="PLANET"; this.info=cfg.info;
    this.wx=this.orbit; this.wy=0;
  }
  update(elapsedDays){
    this.angle=this.angle0+(TAU/this.periodDays)*elapsedDays;
    this.wx=Math.cos(this.angle)*this.orbit; this.wy=Math.sin(this.angle)*this.orbit;
  }
  drawOrbit(ctx, cam, cx, cy){
    const c=cam.toScreen(0,0,cx,cy);
    ctx.strokeStyle="rgba(120,170,255,0.16)"; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(c.x,c.y,this.orbit*cam.zoom,0,TAU); ctx.stroke();
  }
  draw(ctx, cam, cx, cy, selected, showLabel){
    const s=cam.toScreen(this.wx,this.wy,cx,cy), r=Math.max(2,this.radius*cam.zoom);
    if(this.hasRing) this._ring(ctx,s,r,true);
    const sunDir=Math.atan2(-this.wy,-this.wx);
    const lx=s.x+Math.cos(sunDir)*r*0.4, ly=s.y+Math.sin(sunDir)*r*0.4;
    const g=ctx.createRadialGradient(lx,ly,r*0.1,s.x,s.y,r*1.15);
    g.addColorStop(0,this._mix(this.color,255,0.35)); g.addColorStop(0.6,this.color); g.addColorStop(1,this._mix(this.color,0,0.6));
    ctx.globalAlpha=1; ctx.fillStyle=g; ctx.beginPath(); ctx.arc(s.x,s.y,r,0,TAU); ctx.fill();
    if(this.hasRing) this._ring(ctx,s,r,false);
    if(selected){ ctx.strokeStyle="#5ad6e0"; ctx.lineWidth=2; ctx.beginPath(); ctx.arc(s.x,s.y,r+6,0,TAU); ctx.stroke(); }
    if(showLabel && cam.zoom>0.35){ ctx.globalAlpha=0.85; ctx.fillStyle="#cfe0ff"; ctx.font="11px ui-monospace,monospace"; ctx.textAlign="center"; ctx.fillText(this.name,s.x,s.y-r-8); ctx.textAlign="left"; }
  }
  _ring(ctx,s,r,behind){
    ctx.save(); ctx.translate(s.x,s.y); ctx.scale(1,0.32); ctx.rotate(-0.35);
    ctx.strokeStyle=behind?"rgba(220,200,160,0.35)":"rgba(240,225,180,0.7)"; ctx.lineWidth=Math.max(2,r*0.5);
    ctx.beginPath(); behind?ctx.arc(0,0,r*2.0,Math.PI,TAU):ctx.arc(0,0,r*2.0,0,Math.PI); ctx.stroke(); ctx.restore();
  }
  _mix(hex,target,amt){ const c=hex.replace("#",""); const r=parseInt(c.substr(0,2),16),g=parseInt(c.substr(2,2),16),b=parseInt(c.substr(4,2),16); const m=v=>Math.round(v+(target-v)*amt); return `rgb(${m(r)},${m(g)},${m(b)})`; }
}

/* ============================ Asteroid ============================ */
class Asteroid {
  constructor(wx,wy){ this.wx=wx; this.wy=wy; this.vx=rand(-30,30); this.vy=rand(-30,30); this.radius=rand(1.5,3.5); this.color="#9a8c7a"; this.dead=false; this.spin=rand(0,TAU); this.kind="asteroid"; }
  update(dtDays){ this.wx+=this.vx*dtDays; this.wy+=this.vy*dtDays; this.spin+=dtDays; if(Math.hypot(this.wx,this.wy)>4000) this.dead=true; }
  draw(ctx,cam,cx,cy){
    const s=cam.toScreen(this.wx,this.wy,cx,cy), r=Math.max(1.5,this.radius*cam.zoom);
    ctx.globalAlpha=1; ctx.fillStyle=this.color; ctx.beginPath();
    for(let i=0;i<7;i++){ const a=this.spin+(i/7)*TAU; const rr=r*(0.75+0.25*Math.sin(i*2.3)); const px=s.x+Math.cos(a)*rr, py=s.y+Math.sin(a)*rr; i===0?ctx.moveTo(px,py):ctx.lineTo(px,py); }
    ctx.closePath(); ctx.fill();
  }
}

/* ============================ Comet ============================ */
class Comet {
  constructor(wx,wy){ this.wx=wx; this.wy=wy; const a=rand(0,TAU), sp=rand(80,140); this.vx=Math.cos(a)*sp; this.vy=Math.sin(a)*sp; this.radius=rand(2,3.5); this.dead=false; this.trail=[]; this.kind="comet"; }
  update(dtDays){ this.wx+=this.vx*dtDays; this.wy+=this.vy*dtDays; this._push(); if(Math.hypot(this.wx,this.wy)>4500) this.dead=true; }
  _push(){ this.trail.push({x:this.wx,y:this.wy}); if(this.trail.length>28) this.trail.shift(); }
  draw(ctx,cam,cx,cy){
    for(let i=0;i<this.trail.length;i++){ const p=cam.toScreen(this.trail[i].x,this.trail[i].y,cx,cy); const k=i/this.trail.length; ctx.globalAlpha=k*0.5; ctx.fillStyle="#9fdcff"; ctx.beginPath(); ctx.arc(p.x,p.y,Math.max(1,this.radius*cam.zoom*k),0,TAU); ctx.fill(); }
    const s=cam.toScreen(this.wx,this.wy,cx,cy), r=Math.max(2,this.radius*cam.zoom);
    const g=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,r*4); g.addColorStop(0,"#ffffff"); g.addColorStop(0.4,"#bfe9ff"); g.addColorStop(1,"rgba(120,200,255,0)");
    ctx.globalAlpha=1; ctx.fillStyle=g; ctx.beginPath(); ctx.arc(s.x,s.y,r*4,0,TAU); ctx.fill();
    ctx.fillStyle="#fff"; ctx.beginPath(); ctx.arc(s.x,s.y,r,0,TAU); ctx.fill();
  }
}

/* ============================ BlackHole ============================ */
class BlackHole {
  constructor(wx,wy){ this.wx=wx; this.wy=wy; this.radius=9; this.pull=6000; this.dead=false; this.spin=0; this.kind="blackhole"; }
  applyGravity(body,dtDays){
    const dx=this.wx-body.wx, dy=this.wy-body.wy, d2=dx*dx+dy*dy+50, d=Math.sqrt(d2), f=(this.pull/d2)*dtDays;
    body.vx+=(dx/d)*f*60; body.vy+=(dy/d)*f*60; return d;
  }
  update(dtDays){ this.spin+=dtDays*4; }
  draw(ctx,cam,cx,cy){
    const s=cam.toScreen(this.wx,this.wy,cx,cy), r=Math.max(5,this.radius*cam.zoom);
    const ring=ctx.createRadialGradient(s.x,s.y,r,s.x,s.y,r*3.2);
    ring.addColorStop(0,"rgba(155,123,255,0)"); ring.addColorStop(0.55,"rgba(180,120,255,0.55)"); ring.addColorStop(0.8,"rgba(255,140,90,0.35)"); ring.addColorStop(1,"rgba(255,140,90,0)");
    ctx.globalAlpha=1; ctx.fillStyle=ring; ctx.beginPath(); ctx.arc(s.x,s.y,r*3.2,0,TAU); ctx.fill();
    ctx.fillStyle="#000"; ctx.beginPath(); ctx.arc(s.x,s.y,r,0,TAU); ctx.fill();
    ctx.strokeStyle="rgba(200,170,255,0.6)"; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(s.x,s.y,r,0,TAU); ctx.stroke();
  }
}

/* ============================ Net (MQTT 동기화) ============================
   메시지 envelope: { t, id, ... }  ·  토픽: orrery/room/<ROOM>
   t = hello | welcome | cursor | clock | spawn | pos | despawn | bye */
class Net {
  constructor(sim){
    this.sim=sim; this.client=null; this.connected=false;
    this.id=Math.random().toString(36).slice(2,8);
    this.name=""; this.color=colorFor(this.id); this.topic="";
    this.players=new Map();          // id -> {name,color,x,y,tx,ty,lastSeen}
    this.awaitClock=false;
    this.lastCursor=0; this.lastPos=0;
    this._rosterDirty=true;
  }
  connect(name, room, broker){
    if(typeof mqtt==="undefined"){ this.setStatus("err","라이브러리 로드 실패"); return; }
    this.name=name||("Explorer"+Math.floor(rand(10,99)));
    this.color=colorFor(this.id);
    const safeRoom=(room||"alpha").replace(/[^a-zA-Z0-9_-]/g,"").slice(0,24)||"alpha";
    this.topic="orrery/room/"+safeRoom;
    this.setStatus("connecting","접속 중…");
    try {
      this.client=mqtt.connect(broker, {
        clientId:"orrery_"+this.id+Math.random().toString(36).slice(2,5),
        keepalive:30, reconnectPeriod:4000, connectTimeout:8000,
        will:{ topic:this.topic, payload:JSON.stringify({t:"bye",id:this.id}), qos:0 }
      });
    } catch(e){ this.setStatus("err","브로커 주소 오류"); return; }

    this.client.on("connect", ()=>{
      this.connected=true; this.setStatus("on","접속됨 · "+safeRoom);
      this.client.subscribe(this.topic);
      this.awaitClock=true;                                  // 첫 시계 메시지를 받아 동기화
      this.pub({t:"hello", id:this.id, name:this.name, color:this.color});
      this._broadcastMyBodies();                              // 내가 이미 만든 천체 공유
      this._rosterDirty=true;
    });
    this.client.on("message",(t,p)=>{ try{ this.onMsg(JSON.parse(p.toString())); }catch(e){} });
    this.client.on("reconnect", ()=> this.setStatus("connecting","재접속 중…"));
    this.client.on("error", ()=> this.setStatus("err","연결 오류"));
    this.client.on("close", ()=>{ if(this.connected) this.setStatus("connecting","연결 끊김"); });
  }
  disconnect(){
    if(this.client){ this.pub({t:"bye",id:this.id}); try{ this.client.end(true); }catch(e){} }
    this.client=null; this.connected=false;
    this.players.clear(); this.sim.remoteBodies.clear();
    this._rosterDirty=true; this.setStatus("off","오프라인");
  }
  pub(obj){ if(this.connected && this.client) this.client.publish(this.topic, JSON.stringify(obj)); }
  _spawnMsg(b){ return {t:"spawn", id:this.id, bid:b.bid, kind:b.kind, wx:Math.round(b.wx), wy:Math.round(b.wy), vx:b.vx||0, vy:b.vy||0}; }
  _broadcastMyBodies(){ for(const b of this.sim.bodies){ if(b.bid) this.pub(this._spawnMsg(b)); } }

  onMsg(m){
    if(m.id===this.id) return;                                // 내 메시지는 무시
    switch(m.t){
      case "hello":
        this._touchPlayer(m);
        this.pub({t:"welcome", id:this.id, name:this.name, color:this.color, elapsedDays:this.sim.elapsedDays, timeWarp:this.sim.timeWarp});
        this._broadcastMyBodies();                            // 새로 들어온 사람에게 내 천체 알림
        break;
      case "welcome":
        this._touchPlayer(m);
        if(this.awaitClock){ this.sim.elapsedDays=m.elapsedDays; this.sim.setSpeed(m.timeWarp,false); this.awaitClock=false; }
        break;
      case "cursor":
        this._touchPlayer(m); { const pl=this.players.get(m.id); if(pl){ pl.tx=m.x; pl.ty=m.y; } } break;
      case "clock":
        this.sim.elapsedDays=m.elapsedDays; this.sim.setSpeed(m.timeWarp,false); break;
      case "spawn":   this.sim.addRemoteBody(m); break;
      case "pos":     this.sim.updateRemote(m); break;
      case "despawn": this.sim.removeRemoteBody(m.bid); break;
      case "bye":     this._removePlayer(m.id); break;
    }
  }
  _touchPlayer(m){
    let pl=this.players.get(m.id);
    if(!pl){ pl={name:m.name||"?", color:m.color||colorFor(m.id), x:0,y:0,tx:0,ty:0,lastSeen:now()}; this.players.set(m.id,pl); this._rosterDirty=true; }
    if(m.name) pl.name=m.name; if(m.color) pl.color=m.color; pl.lastSeen=now();
  }
  _removePlayer(id){
    if(this.players.delete(id)) this._rosterDirty=true;
    // 떠난 플레이어가 만든 천체 제거
    for(const [bid,rb] of this.sim.remoteBodies){ if(rb.owner===id) this.sim.remoteBodies.delete(bid); }
  }
  // 매 프레임: 커서/위치 전송 + 오래된 플레이어 정리 + 로스터 갱신
  tick(dt){
    if(!this.connected) return;
    const t=now();
    if(t-this.lastCursor>110){
      this.lastCursor=t;
      const w=this.sim.cam.toWorld(this.sim.cursorS.x, this.sim.cursorS.y, this.sim.W/2, this.sim.H/2);
      this.pub({t:"cursor", id:this.id, name:this.name, color:this.color, x:Math.round(w.x), y:Math.round(w.y)});
    }
    if(t-this.lastPos>90){
      this.lastPos=t;
      const items=[]; for(const b of this.sim.bodies){ if(b.bid) items.push([b.bid, Math.round(b.wx), Math.round(b.wy)]); }
      if(items.length) this.pub({t:"pos", id:this.id, items});
    }
    // 6초 이상 소식 없는 플레이어/천체 정리
    for(const [id,pl] of this.players){ if(t-pl.lastSeen>6000) this._removePlayer(id); }
    for(const [bid,rb] of this.sim.remoteBodies){ if(t-rb.lastSeen>6000) this.sim.remoteBodies.delete(bid); }
    if(this._rosterDirty){ this._renderRoster(); this._rosterDirty=false; }
  }
  setStatus(state,text){
    const dot=document.getElementById("mpDot"); dot.className="dot"+(state==="on"?" on":state==="connecting"?" connecting":"");
    document.getElementById("mpStatus").textContent=text;
    const btn=document.getElementById("mpConnect");
    btn.classList.toggle("on", this.connected); btn.textContent=this.connected?"나가기":"접속";
    if(state==="off"||state==="err") btn.classList.remove("on");
  }
  _renderRoster(){
    const box=document.getElementById("mpRoster"); box.innerHTML="";
    if(!this.connected) return;
    const chip=(name,color,me)=>{ const d=document.createElement("div"); d.className="chip"; d.innerHTML=`<span class="cd" style="background:${color};color:${color}"></span>${name}${me?" (나)":""}`; return d; };
    box.appendChild(chip(this.name, this.color, true));
    for(const [id,pl] of this.players) box.appendChild(chip(pl.name, pl.color, false));
  }
  // 원격 플레이어 커서 그리기
  drawCursors(ctx,cam,cx,cy){
    for(const [id,pl] of this.players){
      pl.x+=(pl.tx-pl.x)*0.3; pl.y+=(pl.ty-pl.y)*0.3;
      const s=cam.toScreen(pl.x,pl.y,cx,cy);
      ctx.globalAlpha=0.95; ctx.strokeStyle=pl.color; ctx.lineWidth=2;
      ctx.beginPath(); ctx.arc(s.x,s.y,7,0,TAU); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(s.x,s.y-11); ctx.lineTo(s.x,s.y-4); ctx.moveTo(s.x,s.y+4); ctx.lineTo(s.x,s.y+11);
      ctx.moveTo(s.x-11,s.y); ctx.lineTo(s.x-4,s.y); ctx.moveTo(s.x+4,s.y); ctx.lineTo(s.x+11,s.y); ctx.stroke();
      ctx.fillStyle=pl.color; ctx.font="11px ui-monospace,monospace"; ctx.textAlign="left";
      ctx.fillText(pl.name, s.x+12, s.y+4);
    }
    ctx.globalAlpha=1;
  }
}

/* ============================ Simulation ============================ */
class Simulation {
  constructor(canvas){
    this.canvas=canvas; this.ctx=canvas.getContext("2d");
    this.cam=new Camera(); this.cam.zoom=0.95;
    this.sun=new Sun(); this.planets=this._buildPlanets();
    this.stars=[]; this.bodies=[];              // 내가 만든 천체
    this.remoteBodies=new Map();                // bid -> {inst, owner, tx, ty, lastSeen}
    this.timeWarp=1; this.daysPerSecAt1x=3; this.elapsedDays=0;
    this.selected=null; this.showOrbits=true; this.showLabels=true; this.spawnMode=null;
    this.fps=60; this._fpsAcc=0; this._fpsFrames=0;
    this.cursorS={x:innerWidth/2,y:innerHeight/2};
    this._bidCounter=0;
    this.net=new Net(this);

    this._resize(); this._bindInput(); this._bindMP();
    window.addEventListener("resize", ()=>this._resize());
  }

  _buildPlanets(){
    const D=[
      { name:"수성", color:"#9a9a9a", radius:3.0, orbit:70,  periodDays:88,
        info:{radius:"2,440 km",dist:"5,790만 km",period:"88일",rotation:"58.6일",moons:"0개",desc:"태양에 가장 가까운 가장 작은 행성. 낮과 밤의 온도 차가 극심합니다."} },
      { name:"금성", color:"#e3c87a", radius:5.2, orbit:105, periodDays:225,
        info:{radius:"6,052 km",dist:"1억 820만 km",period:"225일",rotation:"243일 (역행)",moons:"0개",desc:"두꺼운 이산화탄소 대기의 온실효과로 태양계에서 가장 뜨거운 행성."} },
      { name:"지구", color:"#3a86d6", radius:5.5, orbit:145, periodDays:365,
        info:{radius:"6,371 km",dist:"1억 4,960만 km",period:"365일",rotation:"24시간",moons:"1개 (달)",desc:"생명체가 존재하는 것으로 확인된 유일한 행성. 표면에 액체 상태의 물이 존재합니다."} },
      { name:"화성", color:"#d1593b", radius:4.0, orbit:185, periodDays:687,
        info:{radius:"3,390 km",dist:"2억 2,790만 km",period:"687일",rotation:"24.6시간",moons:"2개",desc:"산화철로 붉게 보이는 행성. 태양계 최대 화산 올림푸스 몬스가 있습니다."} },
      { name:"목성", color:"#c9a06b", radius:13, orbit:265, periodDays:4333,
        info:{radius:"69,911 km",dist:"7억 7,850만 km",period:"11.9년",rotation:"9.9시간",moons:"95개",desc:"태양계에서 가장 큰 행성. 거대 가스 행성이며 대적점이라는 거대한 폭풍이 있습니다."} },
      { name:"토성", color:"#dcc89a", radius:11, orbit:340, periodDays:10759, hasRing:true,
        info:{radius:"58,232 km",dist:"14억 3,400만 km",period:"29.5년",rotation:"10.7시간",moons:"146개",desc:"장엄한 고리로 유명한 가스 행성. 고리는 대부분 얼음과 암석 조각으로 이루어져 있습니다."} },
      { name:"천왕성", color:"#8fd6e0", radius:8, orbit:400, periodDays:30687,
        info:{radius:"25,362 km",dist:"28억 7,100만 km",period:"84년",rotation:"17.2시간",moons:"28개",desc:"옆으로 누워 자전하는 얼음 거대 행성. 메테인 대기로 청록색을 띱니다."} },
      { name:"해왕성", color:"#2f5bd6", radius:7.8, orbit:455, periodDays:60190,
        info:{radius:"24,622 km",dist:"44억 9,500만 km",period:"165년",rotation:"16.1시간",moons:"16개",desc:"가장 바깥쪽의 얼음 거대 행성. 태양계에서 가장 강력한 바람이 부는 곳입니다."} },
    ];
    // 결정적 초기 각도(angle0) → 모든 클라이언트가 동일하게 시작
    return D.map((d,i)=> new Planet({...d, angle0:i*0.7}));
  }

  _resize(){
    const dpr=Math.min(window.devicePixelRatio||1,2);
    this.W=innerWidth; this.H=innerHeight;
    this.canvas.width=this.W*dpr; this.canvas.height=this.H*dpr;
    this.canvas.style.width=this.W+"px"; this.canvas.style.height=this.H+"px";
    this.ctx.setTransform(dpr,0,0,dpr,0,0);
    const count=Math.floor((this.W*this.H)/1600);
    this.stars=Array.from({length:clamp(count,120,520)}, ()=> new Star(this.W,this.H));
  }

  /* ----------------------------- 입력 ----------------------------- */
  _bindInput(){
    const cv=this.canvas;
    let dragging=false, moved=false, lastX=0, lastY=0, lastTap=0, pinch=0;

    cv.addEventListener("wheel",(e)=>{ e.preventDefault(); this._zoomAt(e.clientX,e.clientY, e.deltaY<0?1.12:1/1.12); },{passive:false});

    cv.addEventListener("mousedown",(e)=>{ dragging=true; moved=false; lastX=e.clientX; lastY=e.clientY; });
    window.addEventListener("mousemove",(e)=>{ this.cursorS={x:e.clientX,y:e.clientY}; if(!dragging) return; const dx=e.clientX-lastX,dy=e.clientY-lastY; if(Math.abs(dx)+Math.abs(dy)>3) moved=true; this._pan(dx,dy); lastX=e.clientX; lastY=e.clientY; });
    window.addEventListener("mouseup",(e)=>{ if(dragging&&!moved) this._click(e.clientX,e.clientY); dragging=false; });
    cv.addEventListener("dblclick",(e)=> this._double(e.clientX,e.clientY));

    cv.addEventListener("touchstart",(e)=>{ if(e.touches.length===1){ dragging=true; moved=false; lastX=e.touches[0].clientX; lastY=e.touches[0].clientY; this.cursorS={x:lastX,y:lastY}; } else if(e.touches.length===2){ dragging=false; pinch=this._tdist(e.touches); } },{passive:false});
    cv.addEventListener("touchmove",(e)=>{ e.preventDefault();
      if(e.touches.length===1&&dragging){ const t=e.touches[0]; this.cursorS={x:t.clientX,y:t.clientY}; const dx=t.clientX-lastX,dy=t.clientY-lastY; if(Math.abs(dx)+Math.abs(dy)>3) moved=true; this._pan(dx,dy); lastX=t.clientX; lastY=t.clientY; }
      else if(e.touches.length===2){ const nd=this._tdist(e.touches), mid=this._tmid(e.touches); this._zoomAt(mid.x,mid.y,nd/pinch); pinch=nd; } },{passive:false});
    cv.addEventListener("touchend",(e)=>{ if(dragging&&!moved&&e.changedTouches.length){ const t=e.changedTouches[0]; const n=Date.now(); if(n-lastTap<300) this._double(t.clientX,t.clientY); else this._click(t.clientX,t.clientY); lastTap=n; } dragging=false; });

    document.querySelectorAll("#topbar .tbtn").forEach(b=> b.addEventListener("click", ()=> this.setSpeed(parseInt(b.dataset.speed,10), true)));
    document.getElementById("infoClose").addEventListener("click", ()=> this._deselect());
    document.getElementById("spAst").addEventListener("click", ()=> this._setSpawn("asteroid","소행성 생성"));
    document.getElementById("spCom").addEventListener("click", ()=> this._setSpawn("comet","혜성 생성"));
    document.getElementById("spBh").addEventListener("click",  ()=> this._setSpawn("blackhole","블랙홀 생성"));
    document.getElementById("tgOrbit").addEventListener("click",(e)=>{ this.showOrbits=!this.showOrbits; e.currentTarget.classList.toggle("on",this.showOrbits); });
    document.getElementById("tgLabel").addEventListener("click",(e)=>{ this.showLabels=!this.showLabels; e.currentTarget.classList.toggle("on",this.showLabels); });
    document.getElementById("resetView").addEventListener("click", ()=>{ this.cam.target=null; this.cam.x=0; this.cam.y=0; this.cam.zoom=0.95; document.getElementById("tTarget").textContent="SUN"; });

    const hideHint=()=>{ const h=document.getElementById("hint"); if(h) h.style.opacity="0"; };
    cv.addEventListener("pointerdown", hideHint, {once:true});
  }

  /* 멀티플레이 패널 바인딩 */
  _bindMP(){
    document.getElementById("mpName").value="Explorer"+Math.floor(rand(10,99));
    document.getElementById("mpRoom").value="alpha";
    document.getElementById("mpBroker").value="wss://broker.emqx.io:8084/mqtt";
    document.getElementById("mpHead").addEventListener("click",(e)=>{ if(e.target.tagName==="INPUT") return; document.getElementById("mp").classList.toggle("collapsed"); });
    document.getElementById("mpConnect").addEventListener("click",(e)=>{
      e.stopPropagation();
      if(this.net.connected){ this.net.disconnect(); }
      else { this.net.connect(document.getElementById("mpName").value.trim(), document.getElementById("mpRoom").value.trim(), document.getElementById("mpBroker").value.trim()); }
    });
    window.addEventListener("beforeunload", ()=>{ if(this.net.connected) this.net.disconnect(); });
  }

  _tdist(t){ return Math.hypot(t[0].clientX-t[1].clientX, t[0].clientY-t[1].clientY); }
  _tmid(t){ return {x:(t[0].clientX+t[1].clientX)/2, y:(t[0].clientY+t[1].clientY)/2}; }

  _zoomAt(sx,sy,f){
    const b=this.cam.toWorld(sx,sy,this.W/2,this.H/2);
    this.cam.zoom=clamp(this.cam.zoom*f,0.12,12);
    const a=this.cam.toWorld(sx,sy,this.W/2,this.H/2);
    this.cam.x+=b.x-a.x; this.cam.y+=b.y-a.y;
  }
  _pan(dx,dy){ this.cam.target=null; document.getElementById("tTarget").textContent=this.selected?this.selected.name.toUpperCase():"FREE"; this.cam.x-=dx/this.cam.zoom; this.cam.y-=dy/this.cam.zoom; }

  _click(sx,sy){ if(this.spawnMode){ this._spawnAt(sx,sy); return; } const h=this._pick(sx,sy); h?this._select(h):this._deselect(); }
  _double(sx,sy){
    const h=this._pick(sx,sy);
    if(h&&h!==this.sun){ this.cam.target=h; this._select(h); document.getElementById("tTarget").textContent=h.name.toUpperCase(); }
    else if(h===this.sun){ this.cam.target=null; this.cam.x=0; this.cam.y=0; this._select(this.sun); document.getElementById("tTarget").textContent="SUN"; }
  }
  _pick(sx,sy){
    for(const b of [this.sun,...this.planets]){ const s=this.cam.toScreen(b.wx,b.wy,this.W/2,this.H/2); const r=Math.max(10,b.radius*this.cam.zoom); if(Math.hypot(sx-s.x,sy-s.y)<=r+6) return b; }
    return null;
  }
  _select(b){
    this.selected=b; const info=b.info;
    document.getElementById("infoTag").textContent=b.type;
    document.getElementById("infoName").textContent=b.name;
    document.getElementById("infoDesc").textContent=info.desc;
    const sw=document.getElementById("infoSwatch"); sw.style.background=b.color; sw.style.color=b.color;
    document.getElementById("infoStats").innerHTML=`
      <div class="stat"><span class="k">반지름</span><span class="v">${info.radius}</span></div>
      <div class="stat"><span class="k">태양과 거리</span><span class="v">${info.dist}</span></div>
      <div class="stat"><span class="k">공전주기</span><span class="v">${info.period}</span></div>
      <div class="stat"><span class="k">자전주기</span><span class="v">${info.rotation}</span></div>
      <div class="stat"><span class="k">위성 수</span><span class="v">${info.moons}</span></div>`;
    document.getElementById("info").classList.add("show");
  }
  _deselect(){ this.selected=null; document.getElementById("info").classList.remove("show"); }

  // setSpeed: broadcast=true면 다른 플레이어에게도 전파(시간 동기화)
  setSpeed(v, broadcast){
    this.timeWarp=v;
    document.querySelectorAll("#topbar .tbtn").forEach(b=> b.classList.toggle("active", parseInt(b.dataset.speed,10)===v));
    document.getElementById("tWarp").textContent = v===0?"정지":v+"×";
    if(broadcast && this.net.connected) this.net.pub({t:"clock", id:this.net.id, elapsedDays:this.elapsedDays, timeWarp:v});
  }

  _setSpawn(mode,label){
    if(this.spawnMode===mode){ this._clearSpawn(); return; }
    this.spawnMode=mode; document.getElementById("spawnText").textContent=label;
    document.getElementById("spawnBanner").classList.add("show"); this.canvas.style.cursor="crosshair";
  }
  _clearSpawn(){ this.spawnMode=null; document.getElementById("spawnBanner").classList.remove("show"); this.canvas.style.cursor="grab"; }

  _spawnAt(sx,sy){
    const w=this.cam.toWorld(sx,sy,this.W/2,this.H/2);
    let b;
    if(this.spawnMode==="asteroid") b=new Asteroid(w.x,w.y);
    else if(this.spawnMode==="comet") b=new Comet(w.x,w.y);
    else if(this.spawnMode==="blackhole") b=new BlackHole(w.x,w.y);
    b.bid=this.net.id+"-"+(this._bidCounter++);   // 고유 id 부여(소유자=나)
    this.bodies.push(b);
    if(this.net.connected) this.net.pub(this.net._spawnMsg(b));   // 즉시 공유
    this._clearSpawn();
  }

  /* 원격 천체 추가/갱신/삭제 */
  addRemoteBody(m){
    let rb=this.remoteBodies.get(m.bid);
    if(!rb){
      let inst;
      if(m.kind==="asteroid") inst=new Asteroid(m.wx,m.wy);
      else if(m.kind==="comet") inst=new Comet(m.wx,m.wy);
      else inst=new BlackHole(m.wx,m.wy);
      inst.bid=m.bid;
      rb={inst, owner:m.id, tx:m.wx, ty:m.wy, lastSeen:now()};
      this.remoteBodies.set(m.bid, rb);
    } else { rb.tx=m.wx; rb.ty=m.wy; rb.lastSeen=now(); }
  }
  updateRemote(m){
    for(const [bid,wx,wy] of m.items){ const rb=this.remoteBodies.get(bid); if(rb){ rb.tx=wx; rb.ty=wy; rb.lastSeen=now(); } }
  }
  removeRemoteBody(bid){ this.remoteBodies.delete(bid); }

  /* ----------------------------- 물리 ----------------------------- */
  update(dt){
    const dtDays=this.timeWarp*this.daysPerSecAt1x*dt;
    if(dtDays>0) this.elapsedDays+=dtDays;
    this.planets.forEach(p=> p.update(this.elapsedDays));     // 절대 시간 기반(동기화)

    // 원격 천체: 물리 없이 위치 보간만 (소유자가 보낸 좌표로)
    for(const [bid,rb] of this.remoteBodies){
      rb.inst.wx+=(rb.tx-rb.inst.wx)*0.3; rb.inst.wy+=(rb.ty-rb.inst.wy)*0.3;
      if(rb.inst.kind==="comet") rb.inst._push();
      if(rb.inst.kind==="asteroid") rb.inst.spin+=dtDays;
    }

    // 모든 블랙홀(내 것 + 원격) → 내 천체에 중력 적용
    const holes=[];
    for(const b of this.bodies) if(b instanceof BlackHole) holes.push(b);
    for(const [bid,rb] of this.remoteBodies) if(rb.inst instanceof BlackHole) holes.push(rb.inst);

    for(const b of this.bodies){
      if(b instanceof BlackHole){ b.update(dtDays); continue; }
      for(const h of holes){ const d=h.applyGravity(b,dtDays); if(d<h.radius+4) b.dead=true; }  // 흡수
      b.update(dtDays);
    }
    // 내 블랙홀이 행성/태양과 충돌하면 소멸(태양계 보호)
    for(const b of this.bodies){
      if(!(b instanceof BlackHole)) continue;
      for(const p of this.planets){ if(Math.hypot(b.wx-p.wx,b.wy-p.wy)<b.radius+p.radius) b.dead=true; }
      if(Math.hypot(b.wx,b.wy)<this.sun.radius+b.radius) b.dead=true;
    }
    // 죽은 내 천체: 동기화로 삭제 알림
    for(const b of this.bodies){ if(b.dead && b.bid && this.net.connected) this.net.pub({t:"despawn", id:this.net.id, bid:b.bid}); }
    this.bodies=this.bodies.filter(b=>!b.dead);

    this.net.tick(dt);
    this.cam.follow();
  }

  /* ----------------------------- 렌더 ----------------------------- */
  render(t){
    const ctx=this.ctx, cx=this.W/2, cy=this.H/2;
    const bg=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(this.W,this.H));
    bg.addColorStop(0,"#0a1024"); bg.addColorStop(1,"#04050a");
    ctx.fillStyle=bg; ctx.fillRect(0,0,this.W,this.H);

    for(const s of this.stars) s.draw(ctx,t,this.cam.x,this.cam.y);
    ctx.globalAlpha=1;

    if(this.showOrbits) this.planets.forEach(p=> p.drawOrbit(ctx,this.cam,cx,cy));
    this.sun.draw(ctx,this.cam,cx,cy,t);
    this.planets.forEach(p=> p.draw(ctx,this.cam,cx,cy,this.selected===p,this.showLabels));

    for(const [bid,rb] of this.remoteBodies) rb.inst.draw(ctx,this.cam,cx,cy);   // 원격 천체
    for(const b of this.bodies) b.draw(ctx,this.cam,cx,cy);                      // 내 천체
    ctx.globalAlpha=1;

    this.net.drawCursors(ctx,this.cam,cx,cy);   // 다른 플레이어 커서
  }

  _telemetry(){
    document.getElementById("tPlayers").textContent = this.net.connected ? (this.net.players.size+1) : 1;
    document.getElementById("tBodies").textContent = this.bodies.length + this.remoteBodies.size;
    document.getElementById("tFps").textContent = Math.round(this.fps);
    const yr=Math.floor(this.elapsedDays/365), d=Math.floor(this.elapsedDays%365);
    document.getElementById("tElapsed").textContent = yr>0?`${yr}년 ${d}일`:`${d}일`;
  }

  start(){
    let last=performance.now();
    const loop=(t)=>{
      let dt=(t-last)/1000; last=t; dt=Math.min(dt,0.05);
      this._fpsAcc+=dt; this._fpsFrames++;
      if(this._fpsAcc>=0.5){ this.fps=this._fpsFrames/this._fpsAcc; this._fpsAcc=0; this._fpsFrames=0; }
      this.update(dt); this.render(t/1000); this._telemetry();
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  }
}

/* ----------------------------- 부팅 ----------------------------- */
const sim=new Simulation(document.getElementById("stage"));
sim.start();
</script>
